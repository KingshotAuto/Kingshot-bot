<UserControl x:Class="Bot.GUI.Views.ConfigEditorViewImproved"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Bot.GUI.Views"
             xmlns:viewModels="clr-namespace:Bot.GUI.ViewModels"
             xmlns:converters="clr-namespace:Bot.GUI.Converters"
             xmlns:controls="clr-namespace:Bot.GUI.Controls"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance viewModels:ConfigViewModel, IsDesignTimeCreatable=True}"
             Background="#FF2D2D30">
    <UserControl.Resources>
        <local:TaskEnabledReadOnlyConverter x:Key="TaskEnabledReadOnlyConverter" />
        <local:TaskEnabledToCheckedConverter x:Key="TaskEnabledToCheckedConverter" />
        <converters:NotNullToBooleanConverter x:Key="NotNullToBooleanConverter" />
        <converters:TaskTypeToVisibilityConverter x:Key="TaskTypeToVisibilityConverter" />
        <converters:TaskTypeToDisplayNameConverter x:Key="TaskTypeToDisplayNameConverter" />

        <!-- Modern Dark Theme Styles -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#FF2D2D30"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" 
                                Background="#FF3C3C3C" 
                                BorderBrush="#FF555555"
                                BorderThickness="0"
                                Margin="0,0,2,0"
                                MinWidth="100">
                            <ContentPresenter x:Name="ContentSite"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              ContentSource="Header"
                                              Margin="12,8"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF007ACC"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="#FFB0B0B0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF4A4A4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,5"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Margin" Value="0,0,10,5"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF4A4A4A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFB71C1C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFD32F2F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- Danger/Warning CheckBox Style -->
        <Style x:Key="DangerCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFD32F2F"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="false" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="20" />
                                            </Grid.ColumnDefinitions>
                                            <Border x:Name="Border" Grid.ColumnSpan="2" CornerRadius="2" 
                                                    Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}" 
                                                    BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}" 
                                                    BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                            <Path x:Name="Arrow" Grid.Column="1" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z" />
                                        </Grid>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}" 
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                              Margin="{TemplateBinding Padding}" 
                                              VerticalAlignment="Center" HorizontalAlignment="Left"
                                              TextElement.Foreground="Black"/>
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#FF3A3A3A" BorderThickness="1" BorderBrush="#FF555555"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#FF888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="Black"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#FF505050" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Expander">
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Setter Property="Background" Value="#FF333333"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="controls:DragDropListBox">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="Margin" Value="2"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Name="Border" 
                                            Background="{TemplateBinding Background}" 
                                            BorderBrush="#FF555555"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Padding="{TemplateBinding Padding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="⋮⋮" 
                                                       Foreground="#FF888888" 
                                                       FontWeight="Bold" 
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center"/>
                                            <ContentPresenter Grid.Column="1" 
                                                              VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="🖱️" 
                                                       Foreground="#FF888888" 
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#FF007ACC"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#FF4A4A4A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section Header Style -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF007ACC"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Card Style for Sections -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF333333"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <TabControl>
            <!-- General Tab -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20">
                    <StackPanel>
                        <!-- Global Bot Settings -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Global Bot Settings" Style="{StaticResource SectionHeaderStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Max Running Instances:" Grid.Column="0"/>
                                    <TextBox Text="{Binding TotalRunningInstances}" 
                                             Grid.Column="1" Margin="0,0,10,0"/>
                                    <TextBlock Text="Number of bots that can run simultaneously" 
                                               Grid.Column="2" Foreground="#FFB0B0B0" FontSize="12"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Cycle Control Settings -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Cycle Control Settings" Style="{StaticResource SectionHeaderStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Min Wait -->
                                    <TextBlock Text="Min Wait Between Cycles:" Grid.Row="0" Grid.Column="0"/>
                                    <TextBox Text="{Binding MinWaitTimeBetweenCyclesMinutes}" 
                                             Grid.Row="0" Grid.Column="1" Margin="0,0,10,5"
                                             ToolTip="Minimum 1 minute required to prevent memory leaks. Setting to 0 causes system instability."/>
                                    <TextBlock Text="minutes (min: 1)" Grid.Row="0" Grid.Column="2" Foreground="#FFB0B0B0" FontSize="12"/>

                                    <!-- Max Wait -->
                                    <TextBlock Text="Max Wait Between Cycles:" Grid.Row="1" Grid.Column="0"/>
                                    <TextBox Text="{Binding MaxWaitTimeBetweenCyclesMinutes}" 
                                             Grid.Row="1" Grid.Column="1" Margin="0,0,10,5"
                                             ToolTip="Must be greater than or equal to minimum wait time"/>
                                    <TextBlock Text="minutes" Grid.Row="1" Grid.Column="2" Foreground="#FFB0B0B0" FontSize="12"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Accounts Tab -->
            <TabItem Header="Accounts">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" MinWidth="200"/>
                        <ColumnDefinition Width="*" MinWidth="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- Account List -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Bot Accounts" Style="{StaticResource SectionHeaderStyle}"/>
                                <TextBlock Text="Drag accounts to reorder" 
                                           Foreground="#FFB0B0B0" 
                                           FontSize="11" 
                                           FontStyle="Italic"
                                           Margin="0,0,0,8"/>
                            </StackPanel>
                            <controls:DragDropListBox Grid.Row="1" 
                                                      ItemsSource="{Binding Accounts}" 
                                                      SelectedItem="{Binding SelectedAccount}" 
                                                      DisplayMemberPath="AccountName"
                                                      MinHeight="200"
                                                      Margin="0,0,0,10"
                                                      ItemReorderedCommand="{Binding AccountReorderedCommand}"/>
                            <StackPanel Grid.Row="2">
                                <Button Content="Add Account" Command="{Binding AddAccountCommand}" 
                                        Width="Auto" HorizontalAlignment="Stretch" Margin="0,2"/>
                                <Button Content="Remove Selected" Command="{Binding RemoveAccountCommand}" 
                                        Style="{StaticResource DangerButtonStyle}" 
                                        Width="Auto" HorizontalAlignment="Stretch" Margin="0,2"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Account Details -->
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}"
                            IsEnabled="{Binding SelectedAccount, Converter={StaticResource NotNullToBooleanConverter}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Account Information" Style="{StaticResource SectionHeaderStyle}"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="120"/>
                                        <ColumnDefinition Width="*" MinWidth="150"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Text="Account Name:" Grid.Row="0" Grid.Column="0"/>
                                    <TextBox Text="{Binding SelectedAccount.AccountName}" 
                                             Grid.Row="0" Grid.Column="1"/>
                                    
                                    <TextBlock Text="Instance Number:" Grid.Row="1" Grid.Column="0"/>
                                    <TextBox Text="{Binding SelectedAccount.InstanceNumber}" 
                                             Grid.Row="1" Grid.Column="1"/>
                                    
                                    <CheckBox IsChecked="{Binding SelectedAccount.DoNotShutdown}"
                                              Content="Do Not Shutdown"
                                              Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                              Margin="0,10,0,0"
                                              Style="{StaticResource DangerCheckBoxStyle}"
                                              ToolTip="⚠️ WARNING: We do not recommend using this option as it increases the chance of your account being detected by keeping instances running continuously"
                                              ToolTipService.InitialShowDelay="0"
                                              ToolTipService.ShowDuration="60000"/>
                                    
                                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" 
                                                Margin="20,5,0,0" Orientation="Horizontal"
                                                Visibility="{Binding SelectedAccount.DoNotShutdown, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="Wait between task cycles (minutes):" 
                                                   Foreground="White" 
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                        <TextBox Text="{Binding PersistentAccountWaitMinutes}" 
                                                 Width="60" 
                                                 ToolTip="Wait time in minutes between task cycles for persistent accounts. Set to 0 for no wait (immediate continuous execution)"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tasks Tab -->
            <TabItem Header="Tasks">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" MinWidth="200"/>
                        <ColumnDefinition Width="*" MinWidth="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- Account List -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="Select Account" Style="{StaticResource SectionHeaderStyle}"/>
                            <ListBox Grid.Row="1" 
                                     ItemsSource="{Binding Accounts}" 
                                     SelectedItem="{Binding SelectedAccount}" 
                                     DisplayMemberPath="AccountName"
                                     MinHeight="200"/>
                        </Grid>
                    </Border>

                    <!-- Task Selection -->
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}"
                            IsEnabled="{Binding SelectedAccount, Converter={StaticResource NotNullToBooleanConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="Enable Tasks for Selected Account" Style="{StaticResource SectionHeaderStyle}"/>
                            <TextBlock Grid.Row="1" Text="Select which tasks this account should perform" 
                                       Foreground="#FFB0B0B0" FontSize="12" Margin="0,0,0,15"/>
                            
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding AllTaskTypes}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Converter={StaticResource TaskTypeToDisplayNameConverter}}" 
                                                      Margin="5"
                                                      FontSize="14"
                                                      Command="{Binding DataContext.ToggleTaskEnabledCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}">
                                                <CheckBox.IsChecked>
                                                    <MultiBinding Converter="{StaticResource TaskEnabledReadOnlyConverter}">
                                                        <Binding Path="." />
                                                        <Binding Path="DataContext.SelectedAccount" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                    </MultiBinding>
                                                </CheckBox.IsChecked>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            
                            <Button Grid.Row="3" Content="Apply Tasks to All Accounts" 
                                    Margin="0,15,0,0"
                                    Command="{Binding ApplyEnabledTasksToAllCommand}"
                                    HorizontalAlignment="Stretch"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Task Settings Tab -->
            <TabItem Header="Task Settings">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" MinWidth="200"/>
                        <ColumnDefinition Width="*" MinWidth="350"/>
                    </Grid.ColumnDefinitions>

                    <!-- Account List -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="Select Account" Style="{StaticResource SectionHeaderStyle}"/>
                            <ListBox Grid.Row="1" 
                                     ItemsSource="{Binding Accounts}" 
                                     SelectedItem="{Binding SelectedAccount}" 
                                     DisplayMemberPath="AccountName"
                                     MinHeight="200"/>
                        </Grid>
                    </Border>

                    <!-- Task Settings -->
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}"
                            IsEnabled="{Binding SelectedAccount, Converter={StaticResource NotNullToBooleanConverter}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Task Configuration" Style="{StaticResource SectionHeaderStyle}"/>
                                <TextBlock Text="Configure settings for enabled tasks" 
                                           Foreground="#FFB0B0B0" FontSize="12" Margin="0,0,0,15"/>

                                <!-- Combat Tasks Section -->
                                <Expander Header="Combat Tasks" IsExpanded="True" Margin="0,0,0,10">
                                    <StackPanel Margin="20,10,0,0">

                                        <!-- Auto Shield Settings -->
                                        <Border Style="{StaticResource CardStyle}"
                                                Visibility="{Binding SelectedAccount.EnabledTasks, 
                                                            Converter={StaticResource TaskTypeToVisibilityConverter}, 
                                                            ConverterParameter=AutoShield}">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,10">
                                                    <TextBlock Text="Auto Shield" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                                    <Button Content="Apply to All" 
                                                            HorizontalAlignment="Right"
                                                            Padding="8,4"
                                                            FontSize="11"
                                                            Background="#FF007ACC"
                                                            Foreground="White"
                                                            BorderThickness="0"
                                                            Command="{Binding ApplyAutoShieldSettingsToAllCommand}"
                                                            ToolTip="Apply these Auto Shield settings to all accounts"/>
                                                </Grid>
                                                <CheckBox Content="Use Rechargeable Shield (8h)" 
                                                          IsChecked="{Binding SelectedAccount.AutoShieldSettings.UseRechargeableShield}"
                                                          Margin="0,0,0,10"/>
                                                
                                                <TextBlock Text="Backup Shield Type:" Margin="0,0,0,5"/>
                                                <StackPanel Margin="20,0,0,0">
                                                    <RadioButton Content="None" GroupName="BackupShield"
                                                                IsChecked="{Binding SelectedAccount.AutoShieldSettings.SelectedBackupShield, 
                                                                          Converter={StaticResource EnumToBooleanConverter}, 
                                                                          ConverterParameter=None}"/>
                                                    <RadioButton Content="2 Hour Shield" GroupName="BackupShield"
                                                                IsChecked="{Binding SelectedAccount.AutoShieldSettings.SelectedBackupShield, 
                                                                          Converter={StaticResource EnumToBooleanConverter}, 
                                                                          ConverterParameter=TwoHour}"/>
                                                    <RadioButton Content="8 Hour Shield" GroupName="BackupShield"
                                                                IsChecked="{Binding SelectedAccount.AutoShieldSettings.SelectedBackupShield, 
                                                                          Converter={StaticResource EnumToBooleanConverter}, 
                                                                          ConverterParameter=EightHour}"/>
                                                    <RadioButton Content="24 Hour Shield" GroupName="BackupShield"
                                                                IsChecked="{Binding SelectedAccount.AutoShieldSettings.SelectedBackupShield, 
                                                                          Converter={StaticResource EnumToBooleanConverter}, 
                                                                          ConverterParameter=TwentyFourHour}"/>
                                                    <RadioButton Content="72 Hour Shield" GroupName="BackupShield"
                                                                IsChecked="{Binding SelectedAccount.AutoShieldSettings.SelectedBackupShield, 
                                                                          Converter={StaticResource EnumToBooleanConverter}, 
                                                                          ConverterParameter=SeventyTwoHour}"/>
                                                </StackPanel>
                                                
                                                <TextBlock Text="Shield Overlap (minutes):" Margin="0,10,0,5"
                                                          ToolTip="Apply a new shield when the current shield has less than this many minutes remaining"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <TextBox Text="{Binding SelectedAccount.AutoShieldSettings.ShieldOverlapMinutes}" 
                                                            Width="60" 
                                                            ToolTip="If current shield has less than this many minutes remaining, apply a new shield. Default: 30 minutes"/>
                                                    <TextBlock Text=" minutes" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Auto Hunt Settings -->
                                        <Border Style="{StaticResource CardStyle}"
                                                Visibility="{Binding SelectedAccount.EnabledTasks, 
                                                            Converter={StaticResource TaskTypeToVisibilityConverter}, 
                                                            ConverterParameter=AutoHunt}">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,10">
                                                    <TextBlock Text="Auto Hunt" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                                    <Button Content="Apply to All" 
                                                            HorizontalAlignment="Right"
                                                            Padding="8,4"
                                                            FontSize="11"
                                                            Background="#FF007ACC"
                                                            Foreground="White"
                                                            BorderThickness="0"
                                                            Command="{Binding ApplyAutoHuntSettingsToAllCommand}"
                                                            ToolTip="Apply these Auto Hunt settings to all accounts"/>
                                                </Grid>
                                                <CheckBox Content="Use Equalize Button on Bear Attacks" 
                                                          IsChecked="{Binding SelectedAccount.AutoHuntSettings.UseEqualize}"
                                                          Margin="0,0,0,10"
                                                          ToolTip="When enabled, the bot will click the equalize button before attacking bears. When disabled, the bot will skip equalize and proceed directly to deployment."/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Auto Rally Settings -->
                                        <Border Style="{StaticResource CardStyle}"
                                                Visibility="{Binding SelectedAccount.EnabledTasks, 
                                                            Converter={StaticResource TaskTypeToVisibilityConverter}, 
                                                            ConverterParameter=AutoRally}">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,10">
                                                    <TextBlock Text="Auto Rally" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                                    <Button Content="Apply to All" 
                                                            HorizontalAlignment="Right"
                                                            Padding="8,4"
                                                            FontSize="11"
                                                            Background="#FF007ACC"
                                                            Foreground="White"
                                                            BorderThickness="0"
                                                            Command="{Binding ApplyAutoRallySettingsToAllCommand}"
                                                            ToolTip="Apply these Auto Rally settings to all accounts"/>
                                                </Grid>
                                                <CheckBox Content="Auto Join" 
                                                          IsChecked="{Binding SelectedAccount.AutoRallySettings.AutoJoin}"
                                                          Margin="0,0,0,10"
                                                          ToolTip="When enabled, the bot will automatically enable the in-game auto-join rally feature. This allows the game to automatically join rallies without manual intervention."/>
                                                
                                                <!-- Auto Join Timer Configuration -->
                                                <StackPanel Orientation="Horizontal" Margin="20,0,0,10"
                                                           IsEnabled="{Binding SelectedAccount.AutoRallySettings.AutoJoin}">
                                                    <TextBlock Text="Minimum Timer (hours):" 
                                                              VerticalAlignment="Center" 
                                                              Margin="0,0,10,0"
                                                              Foreground="#FFB0B0B0"/>
                                                    <TextBox Text="{Binding SelectedAccount.AutoRallySettings.AutoJoinMinHours, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="60"
                                                            VerticalAlignment="Center"
                                                            ToolTip="If the existing auto-join timer is below this threshold, the bot will restart auto-join to get a fresh timer. Default: 3.0 hours"/>
                                                    <TextBlock Text="hrs" 
                                                              VerticalAlignment="Center" 
                                                              Margin="5,0,0,0"
                                                              Foreground="#FFB0B0B0"/>
                                                </StackPanel>
                                                
                                                <!-- Auto Join Check Interval Configuration -->
                                                <StackPanel Orientation="Horizontal" Margin="20,0,0,10"
                                                           IsEnabled="{Binding SelectedAccount.AutoRallySettings.AutoJoin}">
                                                    <TextBlock Text="Check Interval (hours):" 
                                                              VerticalAlignment="Center" 
                                                              Margin="0,0,10,0"
                                                              Foreground="#FFB0B0B0"/>
                                                    <TextBox Text="{Binding SelectedAccount.AutoRallySettings.AutoJoinCheckIntervalHours, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="60"
                                                            VerticalAlignment="Center"
                                                            ToolTip="How often the bot should check and potentially refresh the auto-join setting. Default: 1.0 hours"/>
                                                    <TextBlock Text="hrs" 
                                                              VerticalAlignment="Center" 
                                                              Margin="5,0,0,0"
                                                              Foreground="#FFB0B0B0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Troop Training Settings -->
                                        <Border Style="{StaticResource CardStyle}"
                                                Visibility="{Binding SelectedAccount.EnabledTasks,
                                                            Converter={StaticResource TaskTypeToVisibilityConverter},
                                                            ConverterParameter=TroopTraining}">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,10">
                                                    <TextBlock Text="Troop Training" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                                    <Button Content="Apply to All"
                                                            HorizontalAlignment="Right"
                                                            Padding="8,4"
                                                            FontSize="11"
                                                            Background="#FF007ACC"
                                                            Foreground="White"
                                                            BorderThickness="0"
                                                            Command="{Binding ApplyTroopTrainingSettingsToAllCommand}"
                                                            ToolTip="Apply these Troop Training settings to all accounts"/>
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Max Troop Train Wait:" Grid.Column="0"
                                                               ToolTip="How long the bot will wait for troops to be trained once time has been detected"
                                                               ToolTipService.InitialShowDelay="0"
                                                               ToolTipService.ShowDuration="60000"/>
                                                    <TextBox Text="{Binding MaxTroopTrainWaitMinutes}"
                                                             Grid.Column="1"
                                                             ToolTip="How long the bot will wait for troops to be trained once time has been detected"
                                                             ToolTipService.InitialShowDelay="0"
                                                             ToolTipService.ShowDuration="60000"/>
                                                    <TextBlock Text="minutes"
                                                               Grid.Column="2" Foreground="#FFB0B0B0" FontSize="12"/>
                                                </Grid>

                                                <!-- Train Level 1 Only Setting -->
                                                <CheckBox Content="Train Level 1 Only"
                                                          IsChecked="{Binding SelectedAccount.TroopTrainingSettings.TrainLevel1Only}"
                                                          Margin="0,10,0,0"
                                                          ToolTip="When enabled, the bot will automatically navigate to Rookie Infantry (Level 1) troops before training"
                                                          ToolTipService.InitialShowDelay="0"
                                                          ToolTipService.ShowDuration="60000"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <!-- Resource Tasks Section -->
                                <Expander Header="Resource Tasks" IsExpanded="True" Margin="0,0,0,10">
                                    <StackPanel Margin="20,10,0,0">
                                        <!-- Farming Settings -->
                                        <Border Style="{StaticResource CardStyle}"
                                                Visibility="{Binding SelectedAccount.EnabledTasks, 
                                                            Converter={StaticResource TaskTypeToVisibilityConverter}, 
                                                            ConverterParameter=Farming}">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,10">
                                                    <TextBlock Text="Farming Targets" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                                    <Button Content="Apply to All" 
                                                            HorizontalAlignment="Right"
                                                            Padding="8,4"
                                                            FontSize="11"
                                                            Background="#FF007ACC"
                                                            Foreground="White"
                                                            BorderThickness="0"
                                                            Command="{Binding ApplyFarmingTargetsToAllCommand}"
                                                            ToolTip="Apply farming targets and settings to all accounts"/>
                                                </Grid>
                                                <!-- Resource Selection Grid -->
                                                <Grid Margin="0,10,0,0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Bread Resource Card -->
                                                    <Border Grid.Row="0" Grid.Column="0" 
                                                            Style="{StaticResource CardStyle}"
                                                            Margin="0,0,5,5"
                                                            Padding="12">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="60"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0" Content="Bread" 
                                                                      IsChecked="{Binding BreadTargetEnabled}"
                                                                      FontWeight="Medium"
                                                                      VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" Text="Lv:" 
                                                                       VerticalAlignment="Center" 
                                                                       Margin="8,0,4,0"
                                                                       Foreground="#FFB0B0B0"/>
                                                            <TextBox Grid.Column="2" 
                                                                     Text="{Binding BreadTargetLevel}"
                                                                     IsEnabled="{Binding BreadTargetEnabled}"
                                                                     ToolTip="Level of bread resources to farm"
                                                                     TextAlignment="Center"/>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Wood Resource Card -->
                                                    <Border Grid.Row="0" Grid.Column="1" 
                                                            Style="{StaticResource CardStyle}"
                                                            Margin="5,0,0,5"
                                                            Padding="12">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="60"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0" Content="Wood" 
                                                                      IsChecked="{Binding WoodTargetEnabled}"
                                                                      FontWeight="Medium"
                                                                      VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" Text="Lv:" 
                                                                       VerticalAlignment="Center" 
                                                                       Margin="8,0,4,0"
                                                                       Foreground="#FFB0B0B0"/>
                                                            <TextBox Grid.Column="2" 
                                                                     Text="{Binding WoodTargetLevel}"
                                                                     IsEnabled="{Binding WoodTargetEnabled}"
                                                                     ToolTip="Level of wood resources to farm"
                                                                     TextAlignment="Center"/>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Stone Resource Card -->
                                                    <Border Grid.Row="1" Grid.Column="0" 
                                                            Style="{StaticResource CardStyle}"
                                                            Margin="0,5,5,0"
                                                            Padding="12">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="60"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0" Content="Stone" 
                                                                      IsChecked="{Binding StoneTargetEnabled}"
                                                                      FontWeight="Medium"
                                                                      VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" Text="Lv:" 
                                                                       VerticalAlignment="Center" 
                                                                       Margin="8,0,4,0"
                                                                       Foreground="#FFB0B0B0"/>
                                                            <TextBox Grid.Column="2" 
                                                                     Text="{Binding StoneTargetLevel}"
                                                                     IsEnabled="{Binding StoneTargetEnabled}"
                                                                     ToolTip="Level of stone resources to farm"
                                                                     TextAlignment="Center"/>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Iron Resource Card -->
                                                    <Border Grid.Row="1" Grid.Column="1" 
                                                            Style="{StaticResource CardStyle}"
                                                            Margin="5,5,0,0"
                                                            Padding="12">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="60"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0" Content="Iron" 
                                                                      IsChecked="{Binding IronTargetEnabled}"
                                                                      FontWeight="Medium"
                                                                      VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" Text="Lv:" 
                                                                       VerticalAlignment="Center" 
                                                                       Margin="8,0,4,0"
                                                                       Foreground="#FFB0B0B0"/>
                                                            <TextBox Grid.Column="2" 
                                                                     Text="{Binding IronTargetLevel}"
                                                                     IsEnabled="{Binding IronTargetEnabled}"
                                                                     ToolTip="Level of iron resources to farm"
                                                                     TextAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                                
                                                <!-- Farming March Limit -->
                                                <Grid Margin="0,15,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Max Farming Marches:" Grid.Column="0"
                                                               ToolTip="Maximum number of farming marches per session. Set to 0 for unlimited marches. This limit persists across task runs for accounts with 'Do Not Shutdown' enabled."
                                                               ToolTipService.InitialShowDelay="0"
                                                               ToolTipService.ShowDuration="60000"/>
                                                    <TextBox Text="{Binding SelectedAccount.FarmingSettings.MaxFarmingMarches}" 
                                                             Grid.Column="1"
                                                             ToolTip="0 = unlimited marches, any other number sets the maximum marches per session"
                                                             ToolTipService.InitialShowDelay="0"
                                                             ToolTipService.ShowDuration="60000"/>
                                                    <TextBlock Text="marches per session"
                                                               Grid.Column="2" Foreground="#FFB0B0B0" FontSize="12"/>
                                                </Grid>

                                                <!-- Gather Boost Settings -->
                                                <CheckBox Content="Enable Gather Boost"
                                                          IsChecked="{Binding SelectedAccount.FarmingBoostSettings.EnableGatherBoost}"
                                                          Margin="0,15,0,10"
                                                          ToolTip="When enabled, the bot will automatically activate gathering boosts before farming"
                                                          ToolTipService.InitialShowDelay="0"
                                                          ToolTipService.ShowDuration="60000"/>

                                                <StackPanel Margin="20,0,0,0"
                                                           Visibility="{Binding SelectedAccount.FarmingBoostSettings.EnableGatherBoost,
                                                                      Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Boost Duration:" Margin="0,0,0,5"/>
                                                    <RadioButton Content="8 Hour Boost" GroupName="BoostDuration" Margin="0,0,0,5"
                                                                IsChecked="{Binding SelectedAccount.FarmingBoostSettings.SelectedBoostDuration,
                                                                          Converter={StaticResource EnumToBooleanConverter},
                                                                          ConverterParameter=EightHour}"
                                                                ToolTip="Use 8-hour gathering boost"
                                                                ToolTipService.InitialShowDelay="0"
                                                                ToolTipService.ShowDuration="60000"/>
                                                    <RadioButton Content="24 Hour Boost" GroupName="BoostDuration"
                                                                IsChecked="{Binding SelectedAccount.FarmingBoostSettings.SelectedBoostDuration,
                                                                          Converter={StaticResource EnumToBooleanConverter},
                                                                          ConverterParameter=TwentyFourHour}"
                                                                ToolTip="Use 24-hour gathering boost"
                                                                ToolTipService.InitialShowDelay="0"
                                                                ToolTipService.ShowDuration="60000"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Conquest Collect Settings -->
                                        <Border Style="{StaticResource CardStyle}"
                                                Visibility="{Binding SelectedAccount.EnabledTasks,
                                                            Converter={StaticResource TaskTypeToVisibilityConverter},
                                                            ConverterParameter=ConquestCollect}">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,10">
                                                    <TextBlock Text="Conquest Collect" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                                    <Button Content="Apply to All"
                                                            HorizontalAlignment="Right"
                                                            Padding="8,4"
                                                            FontSize="11"
                                                            Background="#FF007ACC"
                                                            Foreground="White"
                                                            BorderThickness="0"
                                                            Command="{Binding ApplyConquestCollectSettingsToAllCommand}"
                                                            ToolTip="Apply these Conquest Collect settings to all accounts"/>
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="140"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="Wait Timer:" Grid.Column="0" VerticalAlignment="Center"
                                                              ToolTip="Hours to wait before running Conquest Collect task again"/>
                                                    <TextBox Text="{Binding SelectedAccount.ConquestCollectSettings.WaitHours, UpdateSourceTrigger=PropertyChanged}"
                                                             Grid.Column="1"
                                                             ToolTip="Number of hours to wait before the Conquest Collect task can run again. Range: 1-12 hours. Default: 4 hours. The actual wait time includes a small random variance (±10%) to prevent predictable timing."/>
                                                    <TextBlock Text="hours" Grid.Column="2"
                                                               VerticalAlignment="Center"
                                                               Margin="5,0,0,0"
                                                               Foreground="#FFB0B0B0" FontSize="12"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Auto Build Settings -->
                                        <Border Style="{StaticResource CardStyle}"
                                                Visibility="{Binding SelectedAccount.EnabledTasks, 
                                                            Converter={StaticResource TaskTypeToVisibilityConverter}, 
                                                            ConverterParameter=AutoBuild}">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,10">
                                                    <TextBlock Text="Auto Build" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                                    <Button Content="Apply to All" 
                                                            HorizontalAlignment="Right"
                                                            Padding="8,4"
                                                            FontSize="11"
                                                            Background="#FF007ACC"
                                                            Foreground="White"
                                                            BorderThickness="0"
                                                            Command="{Binding ApplyAutoBuildSettingsToAllCommand}"
                                                            ToolTip="Apply these Auto Build settings to all accounts"/>
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Text="Use Speedups Under:" Grid.Row="0" Grid.Column="0"/>
                                                    <TextBox Text="{Binding SelectedAccount.AutoBuildSettings.MaxSpeedupMinutes}" 
                                                             Grid.Row="0" Grid.Column="1"/>
                                                    <TextBlock Text="minutes" Grid.Row="0" Grid.Column="2" 
                                                               Foreground="#FFB0B0B0" FontSize="12"/>

                                                    <CheckBox Content="Enable Auto Speedup" 
                                                              IsChecked="{Binding SelectedAccount.AutoBuildSettings.EnableAutoSpeedup}"
                                                              Grid.Row="1" Grid.ColumnSpan="3" 
                                                              Margin="0,10,0,0"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <!-- Social Tasks Section -->
                                <Expander Header="Social Tasks" IsExpanded="False" Margin="0,0,0,10">
                                    <StackPanel Margin="20,10,0,0">

                                        <!-- Alliance Technology Settings -->
                                        <Border Style="{StaticResource CardStyle}"
                                                Visibility="{Binding SelectedAccount.EnabledTasks,
                                                            Converter={StaticResource TaskTypeToVisibilityConverter},
                                                            ConverterParameter=AllianceTechnology}">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,10">
                                                    <TextBlock Text="Alliance Technology" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                                    <Button Content="Apply to All"
                                                            HorizontalAlignment="Right"
                                                            Padding="8,4"
                                                            FontSize="11"
                                                            Background="#FF007ACC"
                                                            Foreground="White"
                                                            BorderThickness="0"
                                                            Command="{Binding ApplyAllianceTechnologySettingsToAllCommand}"
                                                            ToolTip="Apply these Alliance Technology settings to all accounts"/>
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="140"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="Wait Timer:" Grid.Column="0" VerticalAlignment="Center"
                                                              ToolTip="Hours to wait before running Alliance Technology task again"/>
                                                    <TextBox Text="{Binding SelectedAccount.AllianceTechnologySettings.WaitHours, UpdateSourceTrigger=PropertyChanged}"
                                                             Grid.Column="1"
                                                             ToolTip="Number of hours to wait before the Alliance Technology task can run again. Range: 1-24 hours. Default: 10 hours. The actual wait time includes a small random variance (±10%) to prevent predictable timing."/>
                                                    <TextBlock Text="hours" Grid.Column="2"
                                                               VerticalAlignment="Center"
                                                               Margin="5,0,0,0"
                                                               Foreground="#FFB0B0B0" FontSize="12"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>