<UserControl x:Class="Bot.GUI.Views.ConfigEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Bot.GUI.Views"
             xmlns:viewModels="clr-namespace:Bot.GUI.ViewModels"
             xmlns:converters="clr-namespace:Bot.GUI.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance viewModels:ConfigViewModel, IsDesignTimeCreatable=True}"
             Background="#FF2D2D30">
    <UserControl.Resources>
        <local:TaskEnabledReadOnlyConverter x:Key="TaskEnabledReadOnlyConverter" />
        <local:TaskEnabledToCheckedConverter x:Key="TaskEnabledToCheckedConverter" />
        <converters:NotNullToBooleanConverter x:Key="NotNullToBooleanConverter" />
        <converters:TaskTypeToVisibilityConverter x:Key="TaskTypeToVisibilityConverter" />
        <converters:TaskTypeToDisplayNameConverter x:Key="TaskTypeToDisplayNameConverter" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,5"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Margin" Value="0,0,10,5"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF505050"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#FF4A4A4A"/>
                                <Setter Property="Foreground" Value="#FF888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FF007ACC"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFD32F2F"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFB71C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,10,5"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,5"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="false" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="20" />
                                            </Grid.ColumnDefinitions>
                                            <Border x:Name="Border" Grid.ColumnSpan="2" CornerRadius="2" 
                                                    Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}" 
                                                    BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}" 
                                                    BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                            <Path x:Name="Arrow" Grid.Column="1" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z" />
                                        </Grid>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}" 
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                              Margin="{TemplateBinding Padding}" 
                                              VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#FF3A3A3A" BorderThickness="1" BorderBrush="#FF555555"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#FF888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#FF505050" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#FFD0D0D0"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#FF3C3C3C" BorderBrush="#FF555555" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0" Padding="8,5">
                                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" TextElement.Foreground="White" TextElement.FontWeight="Bold" />
                            </Border>
                            <Border Grid.Row="1" Background="#FF333333" BorderBrush="#FF555555" BorderThickness="1,0,1,1" CornerRadius="0,0,4,4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Column="0" Grid.Row="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Row="0" Grid.Column="1"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Background="#FF3A3A3A"
                                       Width="12"/>
                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Grid.Row="1" Grid.Column="0"
                                       Orientation="Horizontal"
                                       Value="{TemplateBinding HorizontalOffset}"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                       Background="#FF3A3A3A"
                                       Height="12"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel Margin="15" Background="Transparent">
            
            <GroupBox Header="Global Bot Settings">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Max Running Instances:" Grid.Column="0"/>
                        <TextBox Text="{Binding TotalRunningInstances}" Grid.Column="1" Width="60"/>
                        <TextBlock Text="(Bots running simultaneously)" Grid.Column="2" Foreground="#FFB0B0B0" FontSize="11"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Cycle Control Settings">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="180"/>
                            <ColumnDefinition Width="Auto" MinWidth="60"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Min Wait -->
                            <RowDefinition Height="Auto"/> <!-- Max Wait -->
                            <RowDefinition Height="Auto"/> <!-- Max Cycles -->
                            <RowDefinition Height="Auto"/> <!-- Max Troop Train Wait -->
                            <RowDefinition Height="Auto"/> <!-- Shutdown Checkbox -->
                        </Grid.RowDefinitions>

                        <!-- Row 0: Min Wait -->
                        <TextBlock Text="Min Wait Between Cycles (Mins):" Grid.Row="0" Grid.Column="0"/>
                        <TextBox Text="{Binding MinWaitTimeBetweenCyclesMinutes}" 
                                 ToolTip="Minimum 1 minute required to prevent memory leaks. Setting to 0 causes system instability." 
                                 Grid.Row="0" Grid.Column="1"/>

                        <!-- Row 1: Max Wait -->
                        <TextBlock Text="Max Wait Between Cycles (Mins):" Grid.Row="1" Grid.Column="0"/>
                        <TextBox Text="{Binding MaxWaitTimeBetweenCyclesMinutes}" 
                                 ToolTip="Maximum wait time between cycles in minutes" 
                                 Grid.Row="1" Grid.Column="1"/>

                        <!-- Row 2: Max Cycles -->
                        <TextBlock Text="Max Cycles (0 for infinite):" Grid.Row="2" Grid.Column="0"/>
                        <TextBox Text="{Binding MaxCycles}" 
                                 ToolTip="Maximum number of cycles (0 = unlimited)" 
                                 Grid.Row="2" Grid.Column="1"/>

                        <!-- Row 3: Max Troop Train Wait -->
                        <TextBlock Text="Max Troop Train Wait (Mins):" Grid.Row="3" Grid.Column="0" 
                                   ToolTip="Max idle time waiting for troops to finish before rerunning training."/>
                        <TextBox Text="{Binding MaxTroopTrainWaitMinutes}" 
                                 Grid.Row="3" Grid.Column="1"/>

                        <!-- Row 4: Shutdown After Cycle -->
                        <CheckBox Content="Shutdown Emulators After Cycle" 
                                  IsChecked="{Binding ShutdownEmulatorsAfterCycle}" 
                                  Grid.Row="4" Grid.ColumnSpan="2" 
                                  Margin="0,10,0,0"
                                  ToolTip="If checked, emulators will shut down after each cycle"/>
                    </Grid>
                </StackPanel>
            </GroupBox>
            
            <GroupBox Header="Account Management">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Accounts List and Buttons -->
                    <StackPanel Grid.Column="0" Margin="0,0,15,0" Background="Transparent">
                        <TextBlock Text="Bot Accounts" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ListBox ItemsSource="{Binding Accounts}" 
                                 SelectedItem="{Binding SelectedAccount}" 
                                 DisplayMemberPath="AccountName"
                                 Background="Transparent"
                                 Height="200" MinHeight="100"/>
                        <Button Content="Add Account" Command="{Binding AddAccountCommand}"/>
                        <Button Content="Remove Selected" Command="{Binding RemoveAccountCommand}" Style="{StaticResource DangerButtonStyle}"/>
                    </StackPanel>

                    <!-- Selected Account Details -->
                    <StackPanel Grid.Column="1" MinWidth="350" Background="Transparent"
                              IsEnabled="{Binding SelectedAccount, Converter={StaticResource NotNullToBooleanConverter}}">
                        <GroupBox Header="General Account Info">
                            <StackPanel Background="Transparent" DataContext="{Binding SelectedAccount}">
                                <Grid Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Account Name:" Grid.Row="0" Grid.Column="0"/>
                                    <TextBox Text="{Binding AccountName}" 
                                             Grid.Row="0" Grid.Column="1"/>

                                    <TextBlock Text="Instance #:" Grid.Row="1" Grid.Column="0"/>
                                    <TextBox Text="{Binding InstanceNumber}" 
                                             Grid.Row="1" Grid.Column="1"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Enabled Tasks">
                            <StackPanel Background="Transparent">
                                <ItemsControl ItemsSource="{Binding AllTaskTypes}"
                                            Background="Transparent">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Converter={StaticResource TaskTypeToDisplayNameConverter}}" 
                                                      Margin="0,2"
                                                      Command="{Binding DataContext.ToggleTaskEnabledCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}">
                                                <CheckBox.IsChecked>
                                                    <MultiBinding Converter="{StaticResource TaskEnabledReadOnlyConverter}">
                                                        <Binding Path="." />
                                                        <Binding Path="DataContext.SelectedAccount" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                    </MultiBinding>
                                                </CheckBox.IsChecked>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="Apply to All Accounts" 
                                        Margin="0,10,0,0"
                                        Command="{Binding ApplyEnabledTasksToAllCommand}"/>
                            </StackPanel>
                        </GroupBox>


                        <GroupBox Header="AutoShield Settings" 
                                  Visibility="{Binding SelectedAccount.EnabledTasks, 
                                              Converter={StaticResource TaskTypeToVisibilityConverter}, 
                                              ConverterParameter=AutoShield}">
                            <StackPanel>
                                <!-- Rechargeable Shield Option -->
                                <CheckBox Content="Use Rechargeable Shield (8h)" 
                                          IsChecked="{Binding SelectedAccount.AutoShieldSettings.UseRechargeableShield}"
                                          Margin="0,0,0,10"/>

                                <!-- Backup Shield Selection -->
                                <TextBlock Text="Backup Shield Type:"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,5"/>
                                
                                <StackPanel Margin="20,0,0,0">
                                    <RadioButton Content="None" 
                                                GroupName="BackupShield"
                                                IsChecked="{Binding SelectedAccount.AutoShieldSettings.SelectedBackupShield, 
                                                          Converter={StaticResource EnumToBooleanConverter}, 
                                                          ConverterParameter=None}"
                                                Margin="0,0,0,5"/>
                                    <RadioButton Content="2 Hour Shield" 
                                                GroupName="BackupShield"
                                                IsChecked="{Binding SelectedAccount.AutoShieldSettings.SelectedBackupShield, 
                                                          Converter={StaticResource EnumToBooleanConverter}, 
                                                          ConverterParameter=TwoHour}"
                                                Margin="0,0,0,5"/>
                                    <RadioButton Content="8 Hour Shield" 
                                                GroupName="BackupShield"
                                                IsChecked="{Binding SelectedAccount.AutoShieldSettings.SelectedBackupShield, 
                                                          Converter={StaticResource EnumToBooleanConverter}, 
                                                          ConverterParameter=EightHour}"
                                                Margin="0,0,0,5"/>
                                    <RadioButton Content="24 Hour Shield" 
                                                GroupName="BackupShield"
                                                IsChecked="{Binding SelectedAccount.AutoShieldSettings.SelectedBackupShield, 
                                                          Converter={StaticResource EnumToBooleanConverter}, 
                                                          ConverterParameter=TwentyFourHour}"
                                                Margin="0,0,0,5"/>
                                    <RadioButton Content="72 Hour Shield" 
                                                GroupName="BackupShield"
                                                IsChecked="{Binding SelectedAccount.AutoShieldSettings.SelectedBackupShield, 
                                                          Converter={StaticResource EnumToBooleanConverter}, 
                                                          ConverterParameter=SeventyTwoHour}"
                                                Margin="0,0,0,5"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="AutoBuild Settings" 
                                  Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Max Speedup Minutes -->
                                <TextBlock Text="Use Speedups Under:" Grid.Row="0" Grid.Column="0"/>
                                <TextBox Text="{Binding SelectedAccount.AutoBuildSettings.MaxSpeedupMinutes}" 
                                         Grid.Row="0" Grid.Column="1" Width="60"/>
                                <TextBlock Text="minutes (Will use speedups on timers less than this)" 
                                           Grid.Row="0" Grid.Column="2" Foreground="#FFB0B0B0" FontSize="11"/>

                                <!-- Enable Auto Speedup -->
                                <CheckBox Content="Enable Auto Speedup" 
                                          IsChecked="{Binding SelectedAccount.AutoBuildSettings.EnableAutoSpeedup}"
                                          Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                          Margin="0,10,0,0"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Farming Targets (Select resource and level to farm)">
                            <StackPanel Background="Transparent">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                            HorizontalScrollBarVisibility="Disabled"
                                            MaxHeight="200">
                                    <ItemsControl ItemsSource="{Binding DataContext.SelectedAccountFarmingTargets, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                Background="Transparent">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type viewModels:FarmingTargetViewModel}">
                                                <Border BorderBrush="#FF4A4A4A" BorderThickness="0,0,0,1" Padding="5" Margin="0,2">
                                                    <Grid HorizontalAlignment="Stretch">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ComboBox Grid.Column="0" ItemsSource="{Binding AllResourceTypes}"
                                                                  SelectedItem="{Binding ResourceType}"
                                                                  Background="#FF3A3A3A"
                                                                  BorderBrush="#FF555555"
                                                                  BorderThickness="1"
                                                                  Foreground="White"
                                                                  Margin="0,0,10,0">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding}" Foreground="White"/>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                        <TextBlock Grid.Column="1" Text="Level:" Margin="0,0,5,0"/>
                                                        <TextBox Grid.Column="2" Text="{Binding Level}" Width="40" Margin="0,0,10,0" 
                                                                 Background="#FF3A3A3A"
                                                                 BorderBrush="#FF555555"
                                                                 BorderThickness="1"
                                                                 Foreground="White"/>
                                                        <Button Grid.Column="3" Content="Remove" Style="{StaticResource DangerButtonStyle}" Padding="5,2"
                                                                Command="{Binding DataContext.RemoveFarmingTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Add Farming Target" Margin="0,10,10,0"
                                            Command="{Binding DataContext.AddFarmingTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    <Button Content="Apply to All" Margin="0,10,0,0"
                                            Command="{Binding DataContext.ApplyFarmingTargetsToAllCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>