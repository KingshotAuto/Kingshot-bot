<Window x:Class="Bot.GUI.Views.DevToolsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bot.GUI.Views"
        mc:Ignorable="d"
        Title="Template Creation Tools" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Content="Take Screenshot" Command="{Binding TakeScreenshotCommand}"/>
            <Button Content="Load Template" Command="{Binding LoadTemplateCommand}"/>
            <Button Content="Test Template" Command="{Binding TestTemplateCommand}"/>
            <Button Content="Clear Selection" Command="{Binding ClearSelectionCommand}"/>
            <CheckBox Content="Auto-Copy Coordinates" IsChecked="{Binding AutoCopyCoordinates}"/>
            <CheckBox Content="Auto-Save Template" IsChecked="{Binding AutoSaveTemplate}"/>
        </StackPanel>

        <!-- Main Image Area -->
        <Border Grid.Row="1" Margin="0,10" BorderBrush="Gray" BorderThickness="1">
            <Grid>
                <Image Source="{Binding CurrentScreenshot}" 
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Stretch="Uniform"/>
                
                <!-- Canvas for drawing the selection rectangle -->
                <Canvas x:Name="SelectionCanvas" Background="Transparent"
                        MouseLeftButtonDown="Canvas_MouseLeftButtonDown">
                    <Rectangle x:Name="SelectionRect"
                             Stroke="Red"
                             StrokeThickness="2"
                             Fill="#20FF0000"
                             Visibility="{Binding IsRectangleVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Canvas>
            </Grid>
        </Border>

        <!-- Bottom Status Bar -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Text="{Binding StatusMessage}" 
                       VerticalAlignment="Center"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock Text="Last Match Confidence: " 
                          VerticalAlignment="Center"/>
                <TextBlock Text="{Binding LastMatchConfidence, StringFormat=P2}"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>
                <Button Content="Set Save Location" 
                        Command="{Binding SelectSaveLocationCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window> 