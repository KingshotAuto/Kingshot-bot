<Window x:Class="Bot.GUI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bot.GUI"
        xmlns:views="clr-namespace:Bot.GUI.Views"
        xmlns:converters="clr-namespace:Bot.GUI.Converters"
        mc:Ignorable="d"
        Title="{Binding Version, StringFormat=KingshotAuto v{0}}"
        Height="800" Width="1200"
        MinWidth="1000" MinHeight="700"
        Background="#FF1E1E1E"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- Converters -->
        <converters:ShieldTimeToColorConverter x:Key="ShieldTimeToColorConverter"/>
        <converters:NotNullToVisibilityConverter x:Key="NotNullToVisibilityConverter"/>

        <!-- Modern Color Brushes -->
        <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF0D7377" Offset="0"/>
            <GradientStop Color="#FF14A085" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF4CAF50" Offset="0"/>
            <GradientStop Color="#FF66BB6A" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="DangerGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFD32F2F" Offset="0"/>
            <GradientStop Color="#FFE57373" Offset="1"/>
        </LinearGradientBrush>

        <!-- Modern Button Style for Sidebar -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFB0B0B0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Margin="10,2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF3A3A3A"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Active Tab Button Style -->
        <Style x:Key="ActiveSidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        
        <!-- Modern Card Style -->
        <Style x:Key="ModernCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" 
                                      Opacity="0.3" BlurRadius="8"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Rounded Button Style -->
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" 
                                                  Opacity="0.2" BlurRadius="4"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Sidebar -->
        <Border Grid.Column="0"
                Background="#FF252525"
                BorderBrush="#FF3A3A3A"
                BorderThickness="0,0,1,0">
            <!-- Use a DockPanel so we can dock the Exit button to the bottom -->
            <DockPanel LastChildFill="True">
                <!-- Bottom‐docked Exit button -->
                <Button Name="ExitButton"
                        Content="🚪 Exit"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="Exit_Click"
                        DockPanel.Dock="Bottom"
                        Margin="0,0,0,10"/>
                
                <!-- All other sidebar items go above -->
                <StackPanel DockPanel.Dock="Top">
                    <!-- Logo/Title -->
                    <Border Background="{StaticResource PrimaryGradient}" Padding="24" Margin="0,0,0,20" CornerRadius="0,0,16,16">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" 
                                              Opacity="0.4" BlurRadius="8"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="🎯 KingshotAuto"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Version, StringFormat=v{0}}"
                                       FontSize="12"
                                       Foreground="#FFE0F2F1"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"
                                       FontWeight="Medium"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Navigation Buttons -->
                    <Button Name="BotTabButton"
                            Content="🚀 Bot"
                            Style="{StaticResource ActiveSidebarButtonStyle}"
                            Click="BotTab_Click"/>
                    <Button Name="LogsTabButton"
                            Content="📜 Logs"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="LogsTab_Click"/>
                    <Button Name="SettingsTabButton"
                            Content="⚙️ Settings"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="SettingsTab_Click"/>
                    <Button Name="OtherSettingsTabButton"
                            Content="🔧 Other Settings"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="OtherSettingsTab_Click"/>
                    <Button Name="HelpTabButton"
                            Content="❓ Help"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="HelpTab_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
        
        <!-- Main Content Area -->
        <Grid Grid.Column="1" Background="#FF1E1E1E">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Banner Stack Container -->
            <StackPanel Grid.Row="0" Margin="20,20,20,0">
                
                <!-- English Language Warning Banner -->
                <Border Name="EnglishLanguageBanner"
                        Background="#FFFF5722"
                        Visibility="Visible"
                        Margin="0,0,0,10"
                        CornerRadius="8"
                        BorderBrush="#FFFF3D00"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" 
                                          Opacity="0.3" BlurRadius="4"/>
                    </Border.Effect>
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Warning Icon -->
                        <TextBlock Grid.Column="0"
                                   Text="⚠️"
                                   FontSize="20"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        
                        <!-- Warning Message -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Important: Set Game Language to English"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="Bold"/>
                            <TextBlock Text="For the bot to work correctly, please ensure your game language is set to English in the game settings."
                                       Foreground="#FFFFCCBC"
                                       FontSize="12"
                                       Margin="0,2,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        
                        <!-- Don't Show Again Checkbox -->
                        <StackPanel Grid.Column="2" 
                                    VerticalAlignment="Center" 
                                    Orientation="Horizontal"
                                    Margin="0,0,12,0">
                            <CheckBox Name="DontShowLanguageBannerCheckBox"
                                      Foreground="White"
                                      FontSize="11"
                                      VerticalAlignment="Center"
                                      Checked="DontShowLanguageBanner_Checked">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="CheckBox">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Name="CheckBoxBorder"
                                                                Width="14"
                                                                Height="14"
                                                                Background="Transparent"
                                                                BorderBrush="White"
                                                                BorderThickness="1"
                                                                CornerRadius="2"
                                                                Margin="0,0,6,0">
                                                            <TextBlock Name="CheckMark"
                                                                       Text="✓"
                                                                       Foreground="White"
                                                                       FontSize="10"
                                                                       FontWeight="Bold"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="Collapsed"/>
                                                        </Border>
                                                        <ContentPresenter Content="{TemplateBinding Content}"
                                                                          VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="CheckBoxBorder" Property="Background" Value="White"/>
                                                            <Setter TargetName="CheckMark" Property="Foreground" Value="#FFFF5722"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="CheckBoxBorder" Property="Background" Value="#33FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </CheckBox.Style>
                                Don't show again
                            </CheckBox>
                        </StackPanel>
                        
                        <!-- Close Button -->
                        <Button Grid.Column="3"
                                Name="CloseLanguageBannerButton"
                                Content="✕"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                Width="24"
                                Height="24"
                                FontSize="12"
                                Cursor="Hand"
                                Click="CloseLanguageBanner_Click"
                                ToolTip="Dismiss this warning">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="12">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#33FFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>
                
            </StackPanel>
            
            <!-- Main Content Container -->
            <Grid Grid.Row="1">
            
            <!-- Bot Tab Content -->
            <Grid Name="BotTabContent" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Bot Control Header -->
                <Border Grid.Row="0"
                        Style="{StaticResource ModernCardStyle}"
                        Margin="20,20,20,10">
                    <StackPanel>
                        <TextBlock Text="Bot Control Center"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,15"/>
                        
                        <!-- Bot Controls -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="🚀 Launch Bot"
                                    Width="160"
                                    Height="48"
                                    Background="{StaticResource SuccessGradient}"
                                    Foreground="White"
                                    Style="{StaticResource RoundedButtonStyle}"
                                    Margin="0,0,15,0"
                                    FontSize="14"
                                    Command="{Binding ViewModel.LaunchBotCommand}"/>
                            <Button Width="160"
                                    Height="48"
                                    Foreground="White"
                                    Margin="0,0,15,0"
                                    FontSize="14"
                                    Command="{Binding ViewModel.PauseResumeCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
                                        <Setter Property="Background" Value="#FFFF9800"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ViewModel.IsBotPaused}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource SuccessGradient}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock>
                                    <Run Text="{Binding ViewModel.PauseResumeButtonIcon, Mode=OneWay}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding ViewModel.PauseResumeButtonText, Mode=OneWay}"/>
                                </TextBlock>
                            </Button>
                            <Button Content="🛑 STOP"
                                    Width="140"
                                    Height="48"
                                    Background="{StaticResource DangerGradient}"
                                    Foreground="White"
                                    Style="{StaticResource RoundedButtonStyle}"
                                    FontSize="14"
                                    Command="{Binding ViewModel.StopCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Instance Status -->
                <Border Grid.Row="1"
                        Style="{StaticResource ModernCardStyle}"
                        Margin="20,10,20,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="Instance Status"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <Border Background="{StaticResource PrimaryGradient}"
                                    CornerRadius="16"
                                    Padding="12,6"
                                    Margin="20,0,0,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" 
                                                      Opacity="0.3" BlurRadius="4"/>
                                </Border.Effect>
                                <TextBlock Text="{Binding ViewModel.InstanceVM.Instances.Count, StringFormat={}{0} Instances}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="White"/>
                            </Border>
                        </StackPanel>
                        
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="400">
                            <ItemsControl ItemsSource="{Binding ViewModel.InstanceVM.Instances}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" ItemWidth="330" ItemHeight="140"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FF3A3A3A"
                                                Margin="12"
                                                Padding="16"
                                                CornerRadius="12"
                                                BorderBrush="#FF555555"
                                                BorderThickness="1"
                                                Width="300"
                                                Height="130">
                                            <Border.Effect>
                                                <DropShadowEffect Color="Black"
                                                                  Direction="270"
                                                                  ShadowDepth="3"
                                                                  Opacity="0.4"
                                                                  BlurRadius="6"/>
                                            </Border.Effect>
                                            
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Header with Account Name and Instance Number -->
                                                <StackPanel Grid.Row="0"
                                                            Grid.Column="0"
                                                            Orientation="Horizontal"
                                                            Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding AccountName}"
                                                               FontWeight="Bold"
                                                               Foreground="White"
                                                               FontSize="14"/>
                                                    <Border Background="{StaticResource PrimaryGradient}"
                                                            CornerRadius="12"
                                                            Padding="8,4"
                                                            Margin="10,0,0,0">
                                                        <TextBlock Text="{Binding InstanceNumber, StringFormat=#{0}}"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"/>
                                                    </Border>
                                                </StackPanel>
                                                
                                                <!-- Status Badge -->
                                                <Border Grid.Row="0"
                                                        Grid.Column="1"
                                                        CornerRadius="12"
                                                        Padding="8,3"
                                                        Margin="0,0,0,4">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FF666666"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                    <Setter Property="Background" Value="{StaticResource SuccessGradient}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                    <Setter Property="Background" Value="#FFFF9800"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Starting">
                                                                    <Setter Property="Background" Value="#FFFF9800"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Stopping">
                                                                    <Setter Property="Background" Value="{StaticResource DangerGradient}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Status}"
                                                               FontSize="10"
                                                               FontWeight="Bold"
                                                               Foreground="White"/>
                                                </Border>
                                                
                                                <!-- Current Task Info -->
                                                <StackPanel Grid.Row="1"
                                                            Grid.ColumnSpan="2"
                                                            Margin="0,0,0,6">
                                                    <TextBlock Text="Current Task:"
                                                               FontSize="10"
                                                               Foreground="#FFAAAAAA"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding LastTask}"
                                                               FontSize="11"
                                                               Foreground="#FFCCCCCC"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding LastTask}"/>
                                                </StackPanel>
                                                
                                                <!-- Phase and Shield Info -->
                                                <StackPanel Grid.Row="2"
                                                            Grid.ColumnSpan="2"
                                                            Margin="0,0,0,6">
                                                    <TextBlock Text="{Binding CurrentPhase}"
                                                               FontSize="10"
                                                               Foreground="#FF66BB6A"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding CurrentPhase}"
                                                               Margin="0,0,0,4"/>
                                                    
                                                    <!-- Shield Status -->
                                                    <StackPanel Orientation="Horizontal" 
                                                                Visibility="{Binding ShieldTimeRemaining, Converter={StaticResource NotNullToVisibilityConverter}}">
                                                        <TextBlock Text="🛡️ "
                                                                   FontSize="10"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding ShieldTimeRemaining, StringFormat={}{0:hh\\:mm\\:ss}}"
                                                                   FontSize="10"
                                                                   Foreground="{Binding ShieldTimeRemaining, Converter={StaticResource ShieldTimeToColorConverter}}"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   ToolTip="Shield Time Remaining"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                
                                                <!-- Action Buttons -->
                                                <StackPanel Grid.Row="3"
                                                            Grid.ColumnSpan="2"
                                                            Orientation="Horizontal"
                                                            HorizontalAlignment="Right">
                                                    <Button Content="▶"
                                                            Width="36"
                                                            Height="28"
                                                            Background="{StaticResource SuccessGradient}"
                                                            Foreground="White"
                                                            BorderThickness="0"
                                                            FontSize="12"
                                                            FontWeight="Bold"
                                                            Margin="0,0,6,0"
                                                            ToolTip="Start Instance"
                                                            ToolTipService.InitialShowDelay="0"
                                                            ToolTipService.ShowOnDisabled="True"
                                                            Command="{Binding StartInstanceCommand}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        CornerRadius="6"
                                                                        BorderThickness="0">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect Color="Black" Direction="270" ShadowDepth="1" 
                                                                                          Opacity="0.3" BlurRadius="3"/>
                                                                    </Border.Effect>
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                    
                                                    <Button Content="⏹"
                                                            Width="36"
                                                            Height="28"
                                                            Background="{StaticResource DangerGradient}"
                                                            Foreground="White"
                                                            BorderThickness="0"
                                                            FontSize="12"
                                                            FontWeight="Bold"
                                                            ToolTip="Stop Instance"
                                                            ToolTipService.InitialShowDelay="0"
                                                            ToolTipService.ShowOnDisabled="True"
                                                            Command="{Binding StopInstanceCommand}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        CornerRadius="6"
                                                                        BorderThickness="0">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect Color="Black" Direction="270" ShadowDepth="1" 
                                                                                          Opacity="0.3" BlurRadius="3"/>
                                                                    </Border.Effect>
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- Logs Tab Content -->
            <Grid Name="LogsTabContent" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Style="{StaticResource ModernCardStyle}"
                        Margin="20,20,20,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="📜 Bot Logs"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <Border Background="{StaticResource PrimaryGradient}"
                                    CornerRadius="16"
                                    Padding="8,4"
                                    Margin="15,0,0,0">
                                <TextBlock Text="Real-time"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="White"/>
                            </Border>
                        </StackPanel>
                        
                        <ScrollViewer Grid.Row="1" 
                                      VerticalScrollBarVisibility="Auto"
                                      MaxHeight="600"
                                      Background="#FF1A1A1A">
                            <TextBox x:Name="LogTextBox"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     Background="Transparent"
                                     Foreground="#FFE0E0E0"
                                     BorderThickness="0"
                                     Padding="10"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- Settings Tab Content -->
            <Grid Name="SettingsTabContent" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Settings Header -->
                <Border Grid.Row="0"
                        Style="{StaticResource ModernCardStyle}"
                        Margin="20,20,20,10">
                    <StackPanel>
                        <TextBlock Text="Bot Settings"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="Configure your bot settings and account management"
                                   FontSize="14"
                                   Foreground="#FFB0B0B0"/>
                    </StackPanel>
                </Border>
                
                <!-- Config Editor -->
                <Border Grid.Row="1"
                        Style="{StaticResource ModernCardStyle}"
                        Margin="20,10,20,20">
                    <views:ConfigEditorViewImproved x:Name="ConfigEditorView"/>
                </Border>
            </Grid>
            
            <!-- Other Settings Tab Content -->
            <Grid Name="OtherSettingsTabContent" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Other Settings Header -->
                <Border Grid.Row="0"
                        Style="{StaticResource ModernCardStyle}"
                        Margin="20,20,20,10">
                    <StackPanel>
                        <TextBlock Text="Other Settings"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="Additional configuration options"
                                   FontSize="14"
                                   Foreground="#FFB0B0B0"/>
                    </StackPanel>
                </Border>
                
                <!-- Other Settings Content -->
                <Border Grid.Row="1"
                        Style="{StaticResource ModernCardStyle}"
                        Margin="20,10,20,20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,10">
                            
                            <!-- LDPlayer Path Section -->
                            <StackPanel Margin="0,0,0,30">
                                <TextBlock Text="🎮 LDPlayer Installation Path"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,0,0,8"/>
                                
                                <TextBlock Text="Manually specify the LDPlayer installation directory if auto-detection fails."
                                           FontSize="12"
                                           Foreground="#FFB0B0B0"
                                           Margin="0,0,0,10"
                                           TextWrapping="Wrap"/>
                                
                                <!-- Current Path Display -->
                                <Border Background="#FF2A2A2A"
                                        BorderBrush="#FF444444"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10"
                                        Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="Current Detection Result:"
                                                   FontSize="11"
                                                   Foreground="#FF888888"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Name="CurrentLDPlayerPathText"
                                                   Text="Auto-detecting..."
                                                   FontSize="12"
                                                   Foreground="#FF4CAF50"
                                                   FontFamily="Consolas"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Manual Path Input -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBox Name="ManualLDPlayerPathTextBox"
                                             Grid.Column="0"
                                             Height="35"
                                             Padding="10,8"
                                             FontSize="12"
                                             Background="#FF383838"
                                             Foreground="White"
                                             BorderBrush="#FF666666"
                                             BorderThickness="1"
                                             VerticalContentAlignment="Center"
                                             ToolTip="Enter LDPlayer installation folder path... (e.g., C:\LDPlayer\LDPlayer9)"/>
                                    
                                    <Button Name="BrowseLDPlayerPathButton"
                                            Grid.Column="1"
                                            Content="📁 Browse"
                                            Width="100"
                                            Height="35"
                                            Background="#FF0D7377"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Margin="10,0,0,0"
                                            Style="{StaticResource RoundedButtonStyle}"
                                            Click="BrowseLDPlayerPath_Click"/>
                                </Grid>
                                
                                <!-- Action Buttons -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Name="SetLDPlayerPathButton"
                                            Content="✅ Set Path" 
                                            Width="100"
                                            Height="32"
                                            Background="#FF4CAF50"
                                            Foreground="White"
                                            Style="{StaticResource RoundedButtonStyle}"
                                            Margin="0,0,10,0"
                                            Click="SetLDPlayerPath_Click"/>
                                    
                                    <Button Name="TestLDPlayerPathButton"
                                            Content="🔍 Test Path"
                                            Width="100"
                                            Height="32"
                                            Background="#FFFF9800"
                                            Foreground="White"
                                            Style="{StaticResource RoundedButtonStyle}"
                                            Margin="0,0,10,0"
                                            Click="TestLDPlayerPath_Click"/>
                                    
                                    <Button Name="ResetLDPlayerPathButton"
                                            Content="🔄 Reset"
                                            Width="80"
                                            Height="32"
                                            Background="#FFFF5722"
                                            Foreground="White"
                                            Style="{StaticResource RoundedButtonStyle}"
                                            Click="ResetLDPlayerPath_Click"/>
                                </StackPanel>
                                
                                <!-- Status Messages -->
                                <Border Name="LDPlayerPathStatusBorder"
                                        Background="#FF2A2A2A"
                                        BorderBrush="#FF444444"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10"
                                        Visibility="Collapsed">
                                    <TextBlock Name="LDPlayerPathStatusText"
                                               FontSize="11"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                            
                            <!-- Future Settings Section -->
                            <StackPanel Margin="0,20,0,0">
                                <TextBlock Text="⚙️ Additional Settings"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,0,0,8"/>
                                
                                <TextBlock Text="More configuration options will be added here in future updates."
                                           FontSize="12"
                                           Foreground="#FFB0B0B0"
                                           Margin="0,0,0,10"/>
                            </StackPanel>
                            
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
            
            <!-- Help Tab Content -->
            <Grid Name="HelpTabContent" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="20">
                        
                        <!-- Setup Tutorial Section -->
                        <Border Style="{StaticResource ModernCardStyle}"
                                Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="🎬 Setup Tutorial"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,0,0,15"/>
                                <TextBlock Text="Watch our comprehensive video guide to correctly setup and configure KingshotAuto"
                                           FontSize="14"
                                           Foreground="#FFB0B0B0"
                                           Margin="0,0,0,20"
                                           TextWrapping="Wrap"/>
                                
                                <!-- Video Preview Card -->
                                <Button Name="SetupVideoButton"
                                        Background="#FF2A2A2A"
                                        BorderBrush="#FF444444"
                                        BorderThickness="1"
                                        Margin="0,0,0,20"
                                        Cursor="Hand"
                                        Click="OpenSetupVideo_Click"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch"
                                        Padding="0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#FF2A2A2A"/>
                                            <Setter Property="BorderBrush" Value="#FF444444"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="12">
                                                            <Border.Effect>
                                                                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="3" 
                                                                                  Opacity="0.4" BlurRadius="6"/>
                                                            </Border.Effect>
                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                              Margin="{TemplateBinding Padding}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FF3A3A3A"/>
                                                    <Setter Property="BorderBrush" Value="#FF0D7377"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Grid Margin="20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- YouTube Icon -->
                                        <Border Grid.Column="0"
                                                Background="#FFFF0000"
                                                CornerRadius="8"
                                                Width="60"
                                                Height="60"
                                                Margin="0,0,20,0">
                                            <TextBlock Text="▶"
                                                       FontSize="28"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        
                                        <!-- Video Info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="KingshotAuto Complete Setup Guide"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       Margin="0,0,0,5"/>
                                            <TextBlock Text="Step-by-step tutorial covering installation, configuration, and first-time setup"
                                                       FontSize="12"
                                                       Foreground="#FFB0B0B0"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,5"/>
                                            <TextBlock Text="📺 Watch on YouTube"
                                                       FontSize="12"
                                                       Foreground="{StaticResource PrimaryGradient}"
                                                       FontWeight="Medium"/>
                                        </StackPanel>
                                        
                                        <!-- External Link Icon -->
                                        <TextBlock Grid.Column="2"
                                                   Text="🔗"
                                                   FontSize="20"
                                                   VerticalAlignment="Center"
                                                   Opacity="0.7"/>
                                    </Grid>
                                </Button>
                                
                                <!-- Quick Tips -->
                                <Border Background="#FF2D4B2D"
                                        BorderBrush="#FF4CAF50"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="15">
                                    <StackPanel>
                                        <TextBlock Text="💡 Quick Setup Tips"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="#FF4CAF50"
                                                   Margin="0,0,0,10"/>
                                        <TextBlock FontSize="12" Foreground="#FFE8F5E8" TextWrapping="Wrap">
                                            <Run Text="• "/>
                                            <Run Text="Set your game language to English before starting"/>
                                            <LineBreak/>
                                            <Run Text="• "/>
                                            <Run Text="Make sure LDPlayer is properly installed and configured"/>
                                            <LineBreak/>
                                            <Run Text="• "/>
                                            <Run Text="Run KingshotAuto as Administrator for best compatibility"/>
                                            <LineBreak/>
                                            <Run Text="• "/>
                                            <Run Text="Configure your accounts in Settings before launching the bot"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        
                        <!-- Support Section -->
                        <Border Style="{StaticResource ModernCardStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="🎯"
                                           FontSize="48"
                                           Margin="0,0,0,20"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Need Additional Help?"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,0,0,15"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Get help from our expert support team and active community"
                                           FontSize="16"
                                           Foreground="#FFB0B0B0"
                                           Margin="0,0,0,30"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"/>
                                
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="🌐 Report an Issue"
                                            Width="220"
                                            Height="48"
                                            Background="{StaticResource PrimaryGradient}"
                                            Foreground="White"
                                            Style="{StaticResource RoundedButtonStyle}"
                                            Margin="0,0,15,0"
                                            FontSize="14"
                                            Click="OpenSupportWebsite_Click"/>
                                    <Button Content="💬 Discussions"
                                            Width="170"
                                            Height="48"
                                            Background="#FF7289DA"
                                            Foreground="White"
                                            Style="{StaticResource RoundedButtonStyle}"
                                            FontSize="14"
                                            Click="JoinDiscord_Click"/>
                                </StackPanel>
                                
                                <TextBlock Text="24/7 support • active community members • helpful guides"
                                           FontSize="12"
                                           Foreground="#FFB0B0B0"
                                           Margin="0,20,0,0"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                    </StackPanel>
                </ScrollViewer>
            </Grid>
            
            </Grid> <!-- Closing Main Content Container -->
        </Grid>
    </Grid>
</Window>
