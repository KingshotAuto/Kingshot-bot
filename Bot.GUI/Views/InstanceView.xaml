<UserControl x:Class="Bot.GUI.Views.InstanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Border
        BorderBrush="#FFDDDDDD"
        BorderThickness="1"
        Margin="8"
        CornerRadius="6"
        Background="White">
        
        <StackPanel>
            <!-- Header -->
            <TextBlock
                Text="Bot Instances"
                FontWeight="Bold"
                FontSize="16"
                Margin="8,8,8,4" />

            <!-- Instance Count -->
            <TextBlock
                Margin="8,0,8,8"
                Foreground="Green"
                FontWeight="SemiBold"
                Text="{Binding Instances.Count, StringFormat=Instance count: {0}}" />

            <!-- List of Instances -->
            <ListView
                ItemsSource="{Binding Instances}"
                SelectedItem="{Binding SelectedInstance}"
                Margin="8"
                Background="Transparent"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                ScrollViewer.HorizontalScrollBarVisibility="Auto">
                
                <ListView.View>
                    <GridView>
                        <!-- Instance Number -->
                        <GridViewColumn
                            Header="#"
                            Width="40"
                            DisplayMemberBinding="{Binding InstanceNumber}" />

                        <!-- Account Name -->
                        <GridViewColumn
                            Header="Account"
                            Width="120"
                            DisplayMemberBinding="{Binding AccountName}" />

                        <!-- Status -->
                        <GridViewColumn
                            Header="Status"
                            Width="90"
                            DisplayMemberBinding="{Binding Status}" />

                        <!-- Last Task -->
                        <GridViewColumn
                            Header="Task"
                            Width="120"
                            DisplayMemberBinding="{Binding LastTask}" />

                        <!-- Actions -->
                        <GridViewColumn Header="" Width="Auto">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button
                                            Content="Start"
                                            Width="48"
                                            Margin="2,0"
                                            Command="{Binding DataContext.StartInstanceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                        <Button
                                            Content="Stop"
                                            Width="48"
                                            Margin="2,0"
                                            Command="{Binding DataContext.StopInstanceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </StackPanel>
    </Border>
</UserControl>
