# Include native runtime dependencies (Tesseract/Leptonica DLLs)
!runtimes/
!runtimes/win-x64/
!runtimes/win-x64/native/
!runtimes/win-x64/native/*.dll
!runtimes/win-x86/
!runtimes/win-x86/native/
!runtimes/win-x86/native/*.dll

# Tools and redistributables - but keep VC redistributable
# tools/
!tools/VC_redist.x64.exe
*.redist.exe

